# Copy to .env and fill in real values. NEVER commit .env.

# Tavily
SEARCH_API_KEY=

# AWS (local dev only — Lambda uses IAM Role, not access keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-central-1

# Discord
DISCORD_WEBHOOK_URL=

# Cognitive scoring API (OpenAI-compatible chat completions)
COGNITIVE_API_KEY=
COGNITIVE_BASE_URL=https://api.groq.com/openai/v1
COGNITIVE_MODEL=llama-3.3-70b-versatile
AUTHENTICITY_THRESHOLD=60
RAG_CONTEXT_LIMIT=5
COGNITIVE_TIMEOUT=20
COGNITIVE_MAX_CONCURRENCY=8
DISCORD_TIMEOUT=10
